APP_MODE=free
DATA_DIR=data
CORS_ORIGINS=https://landing-eight-black-83.vercel.app,http://localhost:3000,http://127.0.0.1:3000

# --- Gemini (분석/기획/픽/제안/나레이션) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Higgsfield 생성 ---
# provider: manual(패키지만) | mcp(스킬 위임 핸드오프) | sdk(백엔드 직접 생성)
HIGGSFIELD_PROVIDER=manual
HIGGSFIELD_RUN_BY_DEFAULT=false
HF_KEY=
HF_API_KEY=
HF_API_SECRET=
HIGGSFIELD_IMAGE_MODEL=nano_banana_2
HIGGSFIELD_VIDEO_MODEL=kling3_0
HIGGSFIELD_IMAGE_COUNT=4
HIGGSFIELD_IMAGE_ARGS_JSON={"aspect":"9:16","resolution":"2k"}
HIGGSFIELD_VIDEO_ARGS_JSON={"mode":"pro","aspect":"9:16","duration":6,"sound":"on"}

# --- 나레이션 / TTS (ElevenLabs) ---
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_v3
ELEVENLABS_VOICE_ID=

# --- 메일 알림 (폼 신청 → 우리 메일) ---
# provider: console(로그만) | smtp(Gmail 앱 비번 — 무료) | resend(무료 티어)
EMAIL_PROVIDER=console
NOTIFY_EMAIL=
EMAIL_FROM=kiwi-bot@localhost
# SMTP (Gmail: 2단계 인증 후 '앱 비밀번호' 발급해서 SMTP_PASSWORD 에)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Resend (https://resend.com — API 키 무료 발급)
RESEND_API_KEY=
